# https://aistudio.google.com/apikey 에서 발급
GEMINI_API_KEY=your-gemini-api-key-here
# /ask 등 일반 LLM 호출에 사용되는 모델 (기본: gemini-2.5-flash)
MONIX_MODEL=gemini-2.5-flash
# GEMINI 모델 출력 최대 토큰수(기본: 8192)
MONIX_LLM_MAX_OUTPUT_TOKENS=8192
# Gemini HTTP 호출 타임아웃 초 (기본: 60)
MONIX_LLM_HTTP_TIMEOUT=60

# --- 웹훅 알림 ---
# Discord 웹훅 URL (설정 시 임계치 초과 알림 발송)
# MONIX_DISCORD_WEBHOOK=https://discord.com/api/webhooks/your-webhook-id/your-webhook-token
# Slack 웹훅 URL (설정 시 임계치 초과 알림 발송)
# MONIX_SLACK_WEBHOOK=https://hooks.slack.com/services/your/slack/webhook
# 동일 알림 재발송 대기 시간 초 (기본: 3600 = 1시간)
# MONIX_NOTIFY_COOLDOWN=3600
# 메트릭별 알림 on/off (0 = 비활성, 기본: 모두 1)
# MONIX_NOTIFY_CPU=1
# MONIX_NOTIFY_MEM=1
# MONIX_NOTIFY_DISK=1